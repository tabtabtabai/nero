PROJECT_NAME=nero
# Service user for host OpenCode (default: 1000 if that account exists, else workspace owner uid)
# OPENCODE_UID=1000
# OPENCODE_GID=1000
NERO_EDGE_NETWORK=nero-edge
TZ=UTC
TRAEFIK_MODE=self
OPENCODE_BIND_PORT=4096
# Listen address for host OpenCode: auto from TRAEFIK_MODE (self=0.0.0.0, external=127.0.0.1) unless set here
# OPENCODE_BIND_ADDR=0.0.0.0
OPENCODE_SHELL=/usr/bin/zsh
# npm global package for `opencode` CLI (default: official public package)
# OPENCODE_CLI_PACKAGE=@tabtabtabai/opencode
# OPENCODE_NPM_REGISTRY=https://npm.pkg.github.com
# OPENCODE_NPM_TOKEN=
# npm global package version for `opencode` CLI (default: latest; set a semver tag to pin)
OPENCODE_CLI_VERSION=latest
ENABLE_GITHUB=yes
GITHUB_SSH_KEY=yes

OPENCODE_DOMAIN=agent.example.com
LETSENCRYPT_EMAIL=you@example.com
CF_DNS_API_TOKEN=

OPENCODE_SERVER_USERNAME=nero
OPENCODE_SERVER_PASSWORD=a-very-long-and-secure-password
OPENCODE_MODEL=openai/gpt-5.4
OPENCODE_CLI_VERSION=1.3.17
OPENCODE_BIND_ADDR=0.0.0.0
OPENCODE_UID=0
OPENCODE_GID=0
# Optional: override host workspace path (default: installing user's ~/nero/workspace)
# WORKSPACE_HOST_DIR=/home/ubuntu/nero/workspace

GIT_USER_NAME=
GIT_USER_EMAIL=
GITHUB_TOKEN=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
LOCAL_ENDPOINT=

# Optional OpenCode automation HTTP endpoint used by Nero runs.
# If unset, Nero falls back to a local placeholder path on port 4096.
# OPENCODE_AUTOMATION_URL=http://127.0.0.1:4096/api/automation-run

# Optional override. Local dev defaults to `packages/database/prisma/dev.db`.
# DATABASE_URL=file:/absolute/path/to/nero.db
